# Copy to apps/web/.env.local and fill in. Never commit .env.local.
# Values live in your Supabase dashboard: Project Settings -> API.

# --- Supabase ---------------------------------------------------------------
# Safe to expose to the browser (RLS is the security boundary).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# SERVER-ONLY. Bypasses RLS entirely — never expose to the browser, never
# rename with a NEXT_PUBLIC_ prefix, never log it. Not used yet in Phase 0;
# needed from Phase 1 (presigned uploads, admin jobs).
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Cloudflare R2 (optional — proctoring media storage) ---------------------
# OPTIONAL and OFF by default. Leave all four empty and the app uses Supabase
# Storage for proctoring media exactly as before — nothing below changes any
# behavior until every one of these four is set AND
# NEXT_PUBLIC_STORAGE_PROVIDER=r2 (below). SERVER-ONLY: never expose these to
# the browser, never rename with a NEXT_PUBLIC_ prefix, never log them — see
# apps/web/lib/storage/r2.ts. Runbook for turning this on: README.md
# "Enabling R2" (Vercel env vars, bucket CORS policy, verification steps).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Safe to expose to the browser — selects which storage backend the client
# adapter targets (apps/web/lib/proctor/storage-adapter.ts), never a secret.
# Default (empty, or anything other than "r2") is "supabase" — the current/
# live-pilot behavior. Set to "r2" ONLY after all four R2_* vars above are
# set and the bucket's CORS policy allows this app's origin (README.md
# "Enabling R2").
NEXT_PUBLIC_STORAGE_PROVIDER=

# --- Hubtel SMS (Phase 3a — bulk SMS onboarding, optional) -------------------
# Leave all three empty to use the default LogSmsProvider (lib/sms/log-provider.ts),
# which records what WOULD be sent instead of sending it — safe for local dev
# and demos with no live SMS account. Set all three to switch
# getSmsProvider() (lib/sms/provider.ts) to the real HubtelSmsProvider. Live
# send is deferred until USTED provisions a Hubtel account — see README.md's
# "Classes, enrollment & onboarding" section.
HUBTEL_CLIENT_ID=
HUBTEL_CLIENT_SECRET=
HUBTEL_SENDER=
